# Copy to ~/.flowbee/fleet.env (chmod 600) on each worker box.
FLOWBEE_URL=http://localhost:7070
FLOWBEE_REPO_URL=git@github.com:samhotchkiss/flowbee.git
FLOWBEE_WORKER_MIRRORS_DIR=$HOME/.flowbee/mirrors
FLOWBEE_FLEET_AGENT=codex
FLOWBEE_FLEET_BUILDERS=4
FLOWBEE_LOG_PATH=/tmp/flowbee-fleet.log

# Only set this when the control plane uses FLOWBEE_WORKER_AUTH_SECRET.
FLOWBEE_WORKER_AUTH_SECRET=replace-me

