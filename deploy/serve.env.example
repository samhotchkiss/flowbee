# Copy to ~/.flowbee/serve.env (chmod 600) and fill secret values there.
# Set this to the immutable, checksum-verified release artifact. The managed
# service sources this file, so it overrides any generic service-unit default.
FLOWBEE_BIN=$HOME/.flowbee/bin/flowbee-p1-<sha256-prefix>
FLOWBEE_CONFIG=$HOME/.flowbee/flowbee.yaml
# Keep the control plane on loopback and publish it through Tailscale Serve.
# Remote workers need an explicitly authenticated endpoint when enrolled.
FLOWBEE_PRIVATE_ADDR=127.0.0.1:7070
FLOWBEE_ALLOW_SELF_MERGE=1
FLOWBEE_MIRROR_PATH=$HOME/.flowbee/cp-mirror.git
FLOWBEE_GIT_REMOTE=ssh
FLOWBEE_LOG_PATH=/tmp/flowbee-serve.log

# Secrets stay in the private env file, never in versioned config.
FLOWBEE_GITHUB_TOKEN=github_pat_REPLACE_ME
FLOWBEE_WEBHOOK_SECRET=replace-me

# Flowbee v2 Phase 1. Enable only after the canary gates in
# docs/runbooks/flowbee-v2-phase1-canary.md pass.
FLOWBEE_EPIC_REVIEW_HANDOFF_V2=0
FLOWBEE_PHASE1_DASHBOARD=0
FLOWBEE_CAPACITY_ROUTING_V2=0
FLOWBEE_DRIVER_SOCKET=/tmp/tmux-driver-<uid>/default/api.sock
# The bearer must identify principal flowbee-control. Activation also requires
# GET /v2/meta features.control_principal_origin=true and an authorized, scope-complete
# GET /v2/control/capabilities response. Never hand-edit Driver's token database; use
# `td --json auth token-update ... --add-scope messages:send --reload-pid <pid>`.
FLOWBEE_DRIVER_TOKEN_FILE=$HOME/.config/tmux-driver/flowbee-control.token
FLOWBEE_DRIVER_INSTANCE_REF=local-driver
FLOWBEE_HUMAN_SESSION_KEY_FILE=$HOME/.flowbee/human-session.key
FLOWBEE_HUMAN_GRANTS_FILE=$HOME/.flowbee/human-grants
FLOWBEE_ALERT_WEBHOOK_URL=https://alerts.example.test/flowbee
FLOWBEE_ALERT_WEBHOOK_SECRET_FILE=$HOME/.flowbee/alert-webhook.key
FLOWBEE_EXTERNAL_WATCHDOG_ID=independent-tailnet-host

# Capacity v2 additionally requires an enrolled local collector and exact seat
# identity/lineage bindings. Leave disabled until a complete shadow generation is green.
FLOWBEE_CAPACITY_LOCAL_HOST_ID=control-host-1
FLOWBEE_CAPACITY_COLLECTOR_ID=capacity-local-1
FLOWBEE_CAPACITY_COLLECT_INTERVAL=2m
